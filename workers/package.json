{
  "name": "mosscart-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "prisma generate",
    "db:migrate": "wrangler d1 migrations apply mosscart-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply mosscart-db",
    "db:seed": "wrangler d1 execute mosscart-db --local --file=prisma/seed.sql",
    "db:seed:prod": "wrangler d1 execute mosscart-db --remote --file=prisma/seed.sql",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "@prisma/adapter-d1": "^6.5.0",
    "@prisma/client": "^6.5.0",
    "hono": "^4.7.5",
    "jose": "^6.2.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.6.0"
  }
}
