// Manual: apply semantic payment/checkout API change for impact testing (no commit/push).
pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '20'))
    timeout(time: 10, unit: 'MINUTES')
  }

  parameters {
    string(
      name: 'IMPACT_TARGET_DIR',
      defaultValue: '',
      trim: true,
      description: 'Optional: second clone on this agent to copy changed files into. Empty = only /workspace/mosscart (host).'
    )
  }

  stages {
    stage('Checkout') {
      steps {
        ws('/workspace/mosscart') {
          checkout scm
          // Jenkins checks out by SHA → detached HEAD; reattach branch so host clone is not detached
          sh 'git symbolic-ref -q HEAD >/dev/null || git checkout main 2>/dev/null || git checkout master 2>/dev/null || true'
        }
      }
    }

    stage('Apply impact: payment') {
      steps {
        ws('/workspace/mosscart') {
          withEnv(["IMPACT_TARGET_DIR=${params.IMPACT_TARGET_DIR ?: ''}"]) {
            sh 'bash jenkins/scripts/impact-mutate.sh apply payment'
          }
        }
      }
    }
  }
}
